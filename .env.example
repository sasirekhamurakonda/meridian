# Database (Neon pooled URL for cloud, local for Docker Compose)
# Neon cloud example (use ssl=require for asyncpg, NOT sslmode=require):
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?ssl=require
DATABASE_URL=postgresql+asyncpg://meridian:meridian@localhost:5432/meridian

# Redis (Upstash rediss:// URL for cloud, local for Docker Compose)
REDIS_URL=redis://localhost:6379/0

# LLM — Groq for free cloud hosting, vLLM/LocalAI for local dev
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your-groq-api-key
LLM_MODEL=llama-3.3-70b-versatile
LLM_SSL_VERIFY=true

# Optional API key for client authentication
API_KEY=

# Limits tuned for free tier
MAX_CONCURRENT_JOBS=2
MAX_QUERY_LENGTH=2000
RATE_LIMIT_PER_HOUR=5
TOP_K_PASSAGES=15
JOB_TIMEOUT_SECONDS=600

# Logging
LOG_LEVEL=INFO
